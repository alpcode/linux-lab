#cloud-config
# Real-VM substrate (cloud-init / multipass) for lessons a container cannot host:
# systemd & journald, disks/partitions/LVM, boot targets, multi-interface networking.
# Same selin@staging-server-01 identity as the container images.
#
# Build on a Debian/Ubuntu host:
#   multipass launch --name staging-server-01 --cloud-init user-data 24.04
#   multipass shell staging-server-01
#
# (For RHCSA, launch a Rocky/Alma cloud image with the equivalent settings.)
hostname: staging-server-01
manage_etc_hosts: true

users:
  - name: selin
    groups: [sudo, adm]
    shell: /bin/bash
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    lock_passwd: true

packages:
  - procps
  - iproute2
  - less
  - nano

write_files:
  - path: /home/selin/.bashrc
    append: true
    owner: "selin:selin"
    content: |

      # --- linux-lab recording profile ---
      export LANG=C.UTF-8
      export LC_ALL=C.UTF-8
      PS1='\[\e[1;32m\]\u@\h\[\e[0m\]:\[\e[1;34m\]\w\[\e[0m\]\$ '
      unset PROMPT_COMMAND

  # Baseline so /var/log/auth.log is non-empty at first boot; rsyslog appends
  # real entries as you actually log in (in a VM the log is genuinely live).
  - path: /var/log/auth.log
    owner: "root:adm"
    permissions: "0640"
    content: |
      Jun 14 09:01:22 staging-server-01 sshd[812]: Accepted publickey for selin from 10.0.4.21 port 51844 ssh2
      Jun 14 09:03:47 staging-server-01 sudo:    selin : TTY=pts/0 ; PWD=/home/selin ; USER=root ; COMMAND=/usr/bin/apt update
